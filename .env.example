# ---- Services ----
# When running via docker-compose these default to the service names.
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0

# ---- Vector store ----
QDRANT_COLLECTION=items

# ---- Embedding model ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Embedding dimension for the model above. Override if you change the model.
EMBEDDING_DIM=384

# ---- Dataset (HuggingFace) ----
# Defaults to Amazon product metadata. The loader is dataset-agnostic: point it
# at any text dataset and adjust the column mapping below.
DATASET_NAME=McAuley-Lab/Amazon-Reviews-2023
DATASET_CONFIG=raw_meta_Software
DATASET_SPLIT=full
# Comma-separated list of columns concatenated to form the embedded text.
TEXT_COLUMNS=title,description,features
TITLE_COLUMN=title
ID_COLUMN=parent_asin
# Cap the number of items ingested so the seed stays fast and bounded.
MAX_ITEMS=5000

# ---- Ingestion ----
BATCH_SIZE=256

# ---- Defaults ----
DEFAULT_TOP_K=5
